{
  "version": "0.2.0",
  "description": "QuickClipboard packaged release hosted by boxi-wangji",
  "homepage": "https://github.com/boxi-wangji/QuickClipboard-Package",
  "license": "Freeware",
  "architecture": {
    "64bit": {
      "url": "https://github.com/boxi-wangji/QuickClipboard-Package/releases/download/v0.2.0/QuickClipboard-0.2.0-win64.zip",
      "hash": "d2a785804112476e47c8c1c1f300a99088c1477cc93a598bf6c8dfe79fe029dc"
    }
  },
  "bin": "QuickClipboard.exe",
  "shortcuts": [
    [
      "QuickClipboard.exe",
      "QuickClipboard"
    ]
  ],
  "installer": {
    "script": [
      "$desktop = [Environment]::GetFolderPath('Desktop')",
      "$shortcutPath = Join-Path $desktop 'QuickClipboard.lnk'",
      "$shell = New-Object -ComObject WScript.Shell",
      "$shortcut = $shell.CreateShortcut($shortcutPath)",
      "$shortcut.TargetPath = \"$dir\\QuickClipboard.exe\"",
      "$shortcut.WorkingDirectory = \"$dir\"",
      "$shortcut.IconLocation = \"$dir\\QuickClipboard.exe,0\"",
      "$shortcut.Save()"
    ]
  },
  "uninstaller": {
    "script": [
      "$shortcutPath = Join-Path ([Environment]::GetFolderPath('Desktop')) 'QuickClipboard.lnk'",
      "if (Test-Path $shortcutPath) { Remove-Item $shortcutPath -Force }"
    ]
  },
  "checkver": {
    "github": "https://github.com/boxi-wangji/QuickClipboard-Package"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/boxi-wangji/QuickClipboard-Package/releases/download/v$version/QuickClipboard-$version-win64.zip"
      }
    }
  }
}
